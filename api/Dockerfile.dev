FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Source is bind-mounted at runtime via docker-compose.dev.yml.
# Install at runtime via the compose `command:` to support live editing.
EXPOSE 3001
CMD ["sh", "-c", "pip install --no-cache-dir -e . && uvicorn long_exposure_api.main:app --host 0.0.0.0 --port 3001 --reload"]
