# Per-host config — copy to .env and fill in.

# ─── Postgres / TimescaleDB (the events DB) ─────────────────────────────────
POSTGRES_DB=longexposure
POSTGRES_USER=leuser
POSTGRES_PASSWORD=replace-me

# ─── Temporal metadata Postgres (separate DB for temporal-server) ───────────
TEMPORAL_POSTGRES_USER=temporal
TEMPORAL_POSTGRES_PASSWORD=replace-me

# ─── LLM endpoint (joi homelab; already running) ────────────────────────────
LLAMA_URL=http://llama-large.joi/v1

# ─── Build-time only (Vite reads this when building the frontend) ───────────
VITE_API_BASE_URL=/api

# ─── Optional: HIST source ──────────────────────────────────────────────────
# Default IEX HIST endpoint. Override only if mirroring elsewhere.
IEX_HIST_BASE_URL=https://iextrading.com/api/1.0/hist
